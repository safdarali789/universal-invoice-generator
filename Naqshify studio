<!DOCTYPE html>
<html lang="ur" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>پیشہ ورانہ ڈیزائن جنریٹر</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Nastaliq+Urdu&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f4f4f4; text-align: center; }
        .toolbar { background: #2c3e50; color: white; padding: 15px; border-radius: 8px; margin-bottom: 10px; }
        button { padding: 10px 20px; cursor: pointer; background: #27ae60; color: white; border: none; border-radius: 5px; }
        #canvas-container { border: 5px solid #34495e; display: inline-block; box-shadow: 0 10px 20px rgba(0,0,0,0.3); }
    </style>
</head>
<body>

    <div class="toolbar">
        <button onclick="addText()">نام شامل کریں</button>
        <button onclick="changeTexture('wood')">لکڑی کا ڈیزائن</button>
        <button onclick="changeTexture('gold')">گولڈ ڈیزائن</button>
        <button onclick="downloadImage()">محفوظ کریں (Download)</button>
    </div>

    <div id="canvas-container">
        <canvas id="c" width="600" height="600"></canvas>
    </div>

    <script>
        var canvas = new fabric.Canvas('c');

        // ٹیکسٹ شامل کرنے کا فنکشن
        function addText() {
            var text = new fabric.IText('اپنا نام یہاں لکھیں', { 
                left: 100, top: 250, 
                fontFamily: 'Noto Nastaliq Urdu',
                fontSize: 40,
                fill: '#ffffff',
                shadow: 'rgba(0,0,0,0.5) 5px 5px 5px'
            });
            canvas.add(text);
        }

        // ٹیکسچر تبدیل کرنے کا فنکشن
        function changeTexture(type) {
            let color = (type === 'wood') ? '#8b4513' : '#ffd700';
            canvas.backgroundColor = color;
            canvas.renderAll();
        }

        // ڈاؤن لوڈ فنکشن
        function downloadImage() {
            const dataURL = canvas.toDataURL({ format: 'png', quality: 1.0 });
            const link = document.createElement('a');
            link.download = 'my-design.png';
            link.href = dataURL;
            link.click();
        }
    </script>
</body>
</html>
